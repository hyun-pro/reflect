<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panel_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/overlay_panel_bg"
    android:padding="14dp"
    android:elevation="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/panel_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Reflect"
            android:textSize="13sp"
            android:textColor="@color/fg_secondary"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/panel_close"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/overlay_close_bg"
            android:gravity="center"
            android:text="✕"
            android:textSize="14sp"
            android:textColor="@color/fg_primary" />
    </LinearLayout>

    <TextView
        android:id="@+id/panel_incoming"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="10dp"
        android:textSize="12sp"
        android:textColor="@color/fg_tertiary"
        android:maxLines="2"
        android:ellipsize="end"
        android:singleLine="false" />

    <TextView
        android:id="@+id/sug_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/overlay_chip_bg"
        android:padding="12dp"
        android:layout_marginBottom="8dp"
        android:textSize="14sp"
        android:textColor="@color/fg_primary"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:id="@+id/sug_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/overlay_chip_bg"
        android:padding="12dp"
        android:layout_marginBottom="8dp"
        android:textSize="14sp"
        android:textColor="@color/fg_primary"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:id="@+id/sug_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/overlay_chip_bg"
        android:padding="12dp"
        android:textSize="14sp"
        android:textColor="@color/fg_primary"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:id="@+id/panel_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textSize="11sp"
        android:textColor="@color/fg_dim"
        android:gravity="end"
        android:text="" />
</LinearLayout>
